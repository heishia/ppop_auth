# ===========================================
# PPOP Auth Server - Railway 배포용 환경변수
# ===========================================

# -------------------------------------------
# Database (Supabase Session Pooler)
# -------------------------------------------
DATABASE_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres

# -------------------------------------------
# JWT Keys (줄바꿈을 \n으로 변환한 값)
# -------------------------------------------
JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIB...\n-----END PUBLIC KEY-----

# 토큰 만료 시간
# 권장사항:
# - JWT_ACCESS_EXPIRES_IN: 15m ~ 1h (최소 15분 이상)
# - JWT_REFRESH_EXPIRES_IN: 7d ~ 60d
# ⚠️ 주의: 너무 짧은 시간(1초 미만)으로 설정하면 실사용 불가능
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# -------------------------------------------
# Server
# -------------------------------------------
AUTH_SERVER_PORT=3000
AUTH_SERVER_URL=https://ppop-auth-server.up.railway.app

# -------------------------------------------
# Auth Client URL (로그인 UI)
# -------------------------------------------
AUTH_CLIENT_URL=https://ppop-auth-client.up.railway.app

# -------------------------------------------
# CORS (쉼표로 구분, 와일드카드 지원)
# -------------------------------------------
CORS_ORIGINS=https://ppop-auth-client.up.railway.app,https://ppoplink.up.railway.app,https://*.vercel.app

# -------------------------------------------
# Logout Allowed Domains (쉼표로 구분)
# 로그아웃 후 리다이렉트를 허용할 도메인 목록
# -------------------------------------------
LOGOUT_ALLOWED_DOMAINS=https://ppoplink.site,https://www.ppoplink.site,https://frontend-production-349a.up.railway.app

# -------------------------------------------
# 네이버 클라우드 SMS
# -------------------------------------------
NAVER_SMS_ACCESS_KEY=
NAVER_SMS_SECRET_KEY=
NAVER_SMS_SERVICE_ID=
NAVER_SMS_SENDER=01012345678

# -------------------------------------------
# 관리자 API 키 (openssl rand -hex 32)
# -------------------------------------------
ADMIN_API_KEY=

# -------------------------------------------
# 통합 관리자 계정 (Seed 스크립트용)
# 관리자는 모든 SaaS에서 관리자 권한을 가지며,
# 다른 사용자에게 관리자 권한을 부여/제거할 수도 있음
# -------------------------------------------
ADMIN_EMAIL=admin@ppop.cloud
ADMIN_PASSWORD=ChangeMe123!

# -------------------------------------------
# 소셜 로그인 - 카카오
# https://developers.kakao.com
# -------------------------------------------
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# -------------------------------------------
# 소셜 로그인 - 네이버
# https://developers.naver.com
# -------------------------------------------
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# -------------------------------------------
# 소셜 로그인 - 구글
# https://console.cloud.google.com
# -------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -------------------------------------------
# 이메일 인증 (Gmail SMTP)
# Gmail 앱 비밀번호 발급 방법:
# 1. Google 계정 > 보안 > 2단계 인증 활성화
# 2. 앱 비밀번호 생성 (메일 선택)
# 3. 생성된 16자리 비밀번호를 SMTP_PASS에 입력
# -------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM=your-email@gmail.com
EMAIL_VERIFY_URL=https://ppop-auth-server.up.railway.app/auth/verify-email

# -------------------------------------------
# Firebase (전화번호 인증)
# https://console.firebase.google.com
# -------------------------------------------
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----