# ===========================================
# PPOP Auth Platform - Railway 배포용 환경변수
# ===========================================
# 각 서비스별 환경변수는 해당 폴더의 env.example 참조
# - auth-server/env.example
# - auth-client/env.example

# -------------------------------------------
# [auth-server] Database
# -------------------------------------------
DATABASE_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres

# -------------------------------------------
# [auth-server] JWT Keys
# -------------------------------------------
JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# -------------------------------------------
# [auth-server] URLs
# -------------------------------------------
AUTH_SERVER_PORT=3000
AUTH_SERVER_URL=https://ppop-auth-server.up.railway.app
AUTH_CLIENT_URL=https://ppop-auth-client.up.railway.app

# -------------------------------------------
# [auth-server] CORS
# -------------------------------------------
CORS_ORIGINS=https://ppop-auth-client.up.railway.app,https://ppoplink.up.railway.app

# -------------------------------------------
# [auth-server] SMS (네이버 클라우드)
# -------------------------------------------
NAVER_SMS_ACCESS_KEY=
NAVER_SMS_SECRET_KEY=
NAVER_SMS_SERVICE_ID=
NAVER_SMS_SENDER=

# -------------------------------------------
# [auth-server] Admin API
# -------------------------------------------
ADMIN_API_KEY=

# -------------------------------------------
# [auth-server] 소셜 로그인
# -------------------------------------------
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# -------------------------------------------
# [auth-client] API URL
# -------------------------------------------
NEXT_PUBLIC_AUTH_API_URL=https://ppop-auth-server.up.railway.app
